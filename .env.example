# TiDB Cloud Serverless — https://tidbcloud.com/
# Copy the connection string from Console → Clusters → Connect → "General"
TIDB_HOST=gateway01.us-west-2.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=xxxxxxxxxxxxx.root
TIDB_PASSWORD=
TIDB_DATABASE=memory_bench
TIDB_SSL_CA=/etc/ssl/cert.pem

# LLM provider (Gemini — used for writes, answers, judging, and embeddings)
GEMINI_API_KEY=

# Models (all Gemini 3.1 family — see src/llm.ts for defaults)
WRITE_MODEL=gemini-3.1-flash-lite-preview
ANSWER_MODEL=gemini-3.1-flash-lite-preview
JUDGE_MODEL=gemini-3.1-pro-preview
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536

# Bench config (all optional)
# PER_SLICE=10                 # questions per slice (4 slices × PER_SLICE total)
# APPROACHES=typed_facts,raw_vector   # comma-separated subset; default is all 5
# SKIP_INGEST=1                # reuse previously ingested data on a re-run
# LME_ORACLE_PATH=/path/to/longmemeval_oracle.json  # override default fixture path
